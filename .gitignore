# ====================================================================
# EO Digital Lab - Hardened .gitignore Template (Web & Lab Environments)
# ====================================================================

# 1. İşletim Sistemi Kalıntıları (OS Garbage)
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# 2. Yerel Notlar ve Kişisel Alan (Local Notes & Knowledge Base)
.obsidian/
*.local
.env
.env.*
secrets.*
*.session

# 3. Editör ve IDE Çöpleri (IDE Configs)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# 4. Geçici Dosyalar ve Yedekler (Temporary Files & Backups)
*.bak
*.tmp
*.temp
*.log
*.err
crash.txt

# 5. Olası Python / Laboratuvar Kalıntıları (Lab Environments)
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
